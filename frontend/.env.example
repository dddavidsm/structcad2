# Copia este archivo como .env.local y rellena los valores

# URL de tu proyecto Supabase (https://app.supabase.com → Settings → API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anonima publica de Supabase (pestaña API → anon public)
VITE_SUPABASE_ANON_KEY=tu_clave_anon_aqui

# URL del backend FastAPI.
# - En produccion con Vercel: dejar VACIO (vercel.json proxea /generate/* a Render).
# - En desarrollo local (si el backend corre en otro puerto): http://localhost:8000
# - Acceso directo a Render sin proxy: https://structcad2-backend.onrender.com
VITE_API_URL=
