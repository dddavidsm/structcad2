# Copia este archivo como .env.local y rellena los valores

# URL de tu proyecto Supabase (https://app.supabase.com → Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anonima publica de Supabase
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del backend FastAPI (dejar vacio para usar el mismo origen en produccion)
VITE_API_URL=
