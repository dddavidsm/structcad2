# .claudeignore

# Dependencias Node y Python
frontend/node_modules/
backend/__pycache__/
venv/
env/

# Compilados de Vite y Vercel
frontend/dist/
.vercel/

# Archivos de entorno y logs
.env
*.log

# Bloqueos de paquetes (Claude no necesita leer 10.000 líneas de dependencias)
frontend/package-lock.json

# Assets pesados e imágenes (no contienen código útil para la IA)
frontend/public/*.svg
frontend/public/*.png
frontend/public/*.ico
frontend/src/assets/